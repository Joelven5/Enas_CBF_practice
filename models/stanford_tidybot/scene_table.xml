<mujoco model="tidybot scene with table">
  <include file="tidybot.xml"/>

  <statistic center="0.25 0 0.6" extent="1.0" meansize="0.05"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5"/>
    <material name="table_mat" rgba="0.55 0.4 0.28 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Simple table in front of the robot for CBF testing -->
    <body name="table" pos="0.75 0 0.15">
      <geom name="table_top" type="box" size="0.35 0.45 0.02" pos="0 0 0.15" material="table_mat"/>
      <geom name="table_leg1" type="box" size="0.02 0.02 0.15" pos="0.3 0.4 0" material="table_mat"/>
      <geom name="table_leg2" type="box" size="0.02 0.02 0.15" pos="-0.3 0.4 0" material="table_mat"/>
      <geom name="table_leg3" type="box" size="0.02 0.02 0.15" pos="0.3 -0.4 0" material="table_mat"/>
      <geom name="table_leg4" type="box" size="0.02 0.02 0.15" pos="-0.3 -0.4 0" material="table_mat"/>
    </body>

    <body name="cube" pos="0.6 0 0.02">
      <freejoint/>
      <geom type="box" size="0.02 0.02 0.02" rgba=".5 .7 .5 1" mass="0.1"/>
    </body>
  </worldbody>
</mujoco>
